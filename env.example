# ══════════════════════════════════════════════════════════════════════════════
# NeuroLens — Environment Variables
# Copy this file: cp .env.example .env
# Fill in your actual keys — NEVER commit .env to git
# ══════════════════════════════════════════════════════════════════════════════

# ─── Python Path (critical for imports to work) ───────────────────────────────
PYTHONPATH=src

# ─── Weights & Biases (experiment tracking) ───────────────────────────────────
WANDB_API_KEY=your_wandb_api_key_here
WANDB_PROJECT=neurolens
WANDB_ENTITY=your_wandb_username

# ─── HuggingFace (model hosting + demo deployment) ────────────────────────────
HF_TOKEN=your_huggingface_token_here
HF_REPO_ID=your_username/neurolens

# ─── API Configuration ────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# ─── Model Paths ──────────────────────────────────────────────────────────────
MODEL_CHECKPOINT_PATH=checkpoints/best_model.pt
ONNX_MODEL_PATH=deployment/model.onnx

# ─── Federated Learning ───────────────────────────────────────────────────────
FL_SERVER_HOST=localhost
FL_SERVER_PORT=8080
FL_NUM_ROUNDS=50
FL_MIN_CLIENTS=3
